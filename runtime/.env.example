# API 认证 (二选一)
# 方式1: 直连 Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
# 方式2: 第三方代理 (如 DeepSeek / OpenRouter)
ANTHROPIC_AUTH_TOKEN=sk-...
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Session storage root
WORKSPACE_ROOT=/workspaces

# fast-harness plugin path (absolute or relative to runtime/)
HARNESS_PLUGIN_PATH=../plugin

# Server
HOST=0.0.0.0
PORT=8000

# Git credentials (optional — for workspace repo cloning)
GIT_GITHUB_TOKEN=
GIT_CODEUP_TOKEN=
GIT_SSH_KEY_PATH=
GIT_DEFAULT_BRANCH=main

# Limits
DEFAULT_MAX_TURNS=30
DEFAULT_MAX_BUDGET_USD=10.0
SESSION_CLEANUP_DAYS=7

# Logging
LOG_LEVEL=INFO
