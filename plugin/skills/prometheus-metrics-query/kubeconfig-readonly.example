# 复制为 kubeconfig-readonly 后填写
# 需要从集群重新生成，参考 deploy/monitor/openclaw/generate-kubeconfig.sh
apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: <填写 CA 数据>
    server: https://172.16.37.101:6443
  name: kubernetes
contexts:
- context:
    cluster: kubernetes
    namespace: drama-prod
    user: openclaw-monitor
  name: openclaw-monitor-ctx
current-context: openclaw-monitor-ctx
users:
- name: openclaw-monitor
  user:
    token: <填写 token>
