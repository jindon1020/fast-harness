{
  "$comment": "fast-harness 基础设施配置模板。复制为 infrastructure.json 并填写实际值，或运行 configure.sh 交互式生成。",

  "mysql": {
    "local": {
      "host": "127.0.0.1",
      "port": 3306,
      "user": "root",
      "password": "123456",
      "database": "my-db"
    },
    "dev": {
      "host": "10.0.1.100",
      "port": 3306,
      "user": "readonly",
      "password": "",
      "database": "my-db-dev",
      "bastion": {
        "host": "jump.example.com",
        "port": 22,
        "user": "deploy",
        "key_path": ".local/id_rsa",
        "local_port": 13306
      }
    },
    "prod": {
      "host": "10.0.2.100",
      "port": 3306,
      "user": "readonly",
      "password": "",
      "database": "my-db-prod",
      "bastion": {
        "host": "jump.example.com",
        "port": 22,
        "user": "deploy",
        "key_path": ".local/id_rsa",
        "local_port": 13307
      }
    }
  },

  "redis": {
    "local": {
      "host": "127.0.0.1",
      "port": 6379,
      "password": "",
      "db": 0
    }
  },

  "kafka": {
    "dev": {
      "brokers": ["10.0.1.50:9092"],
      "group_id": "debug-consumer"
    }
  },

  "elasticsearch": {
    "dev": {
      "hosts": ["http://10.0.1.60:9200"],
      "index_pattern": "app-logs-*"
    }
  },

  "kubernetes": {
    "kubeconfig_path": ".local/kubeconfig-readonly",
    "bastion": {
      "host": "jump.example.com",
      "port": 22,
      "user": "deploy",
      "key_path": ".local/id_rsa",
      "k8s_api_host": "172.16.0.1",
      "k8s_api_port": 6443,
      "local_port": 16443,
      "bind_address": "127.0.0.1"
    },
    "namespaces": {
      "prod": "my-app-prod",
      "dev": "my-app-dev",
      "loki": "loki",
      "prometheus": "arms-prom"
    },
    "loki": {
      "service": "loki",
      "service_port": 3100,
      "local_port": 3100
    },
    "prometheus": {
      "service": "arms-prom-server",
      "service_port": 9090,
      "local_port": 19090
    }
  }
}
